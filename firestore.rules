
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Check for the custom 'admin' claim on the user's token.
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // --- Collections ---
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isUser(userId) || isAdmin();
      allow delete: if isAdmin(); 
    }
    
    match /groups/{groupId} {
      // Admins have full access.
      allow read, write: if isAdmin();
      
      // Members can read groups they belong to.
      // Support both legacy `memberIds` (string[]) and new `members` (object[]) fields
      allow read: if isSignedIn() && (
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds) ||
        (resource.data.members != null && request.auth.uid in resource.data.members.map(m, m.uid))
      );
      
      // Any authenticated user can create a group.
      allow create: if isSignedIn();
      
      // Update rule is more permissive for specific cases.
      allow update: if resource.data.archivedAt == null && (
        (
          // Creator can update general info (support both schema versions)
          request.auth.uid == resource.data.createdById ||
          (resource.data.createdBy != null && request.auth.uid == resource.data.createdBy.uid)
        ) ||
        (
          // Members can ONLY update totalExpenses for expense add/delete operations
          (
            (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds) ||
            (resource.data.members != null && request.auth.uid in resource.data.members.map(m, m.uid))
          ) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalExpenses'])
        )
      );
    }

    match /expenses/{expenseId} {
      // Admins have full access.
      allow read, write: if isAdmin();
      
      // Members can read expenses in groups they belong to.
      allow read: if isSignedIn() && request.auth.uid in resource.data.groupMemberIds;

      // Any member can create/update an expense in an active group.
      allow create, update: if get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.archivedAt == null 
                         && (request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds);

      // Any member can delete an expense from an active group.
      allow delete: if get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.archivedAt == null 
                 && (request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds);
    }
    
    match /settlements/{settlementId} {
       // Admins have full access.
       allow read, write: if isAdmin();
      
      // Members can read settlements in groups they belong to.
      allow read: if isSignedIn() && request.auth.uid in resource.data.groupMemberIds;

      // Any member can create/update a settlement in an active group.
      allow create, update: if get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.archivedAt == null
                   && (request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds);

      // Any member can delete a settlement from an active group.
      allow delete: if get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.archivedAt == null
                   && (request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.memberIds);
    }
    
    match /history/{historyId} {
        allow read, write: if isAdmin();
        
        // Members can read history for their groups.
        allow read: if isSignedIn() && request.auth.uid in resource.data.groupMemberIds;

        // History creates must come from an actual group member acting as themselves.
        // This prevents fake audit log injection.
        allow create: if isSignedIn()
            && request.auth.uid in request.resource.data.groupMemberIds
            && request.resource.data.actorId == request.auth.uid;

        // Members can only update the `restored` flag (for expense/settlement restore).
        allow update: if (request.auth.uid in resource.data.groupMemberIds)
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['restored']);
    }
    
    match /settings/{docId} {
        // Settings are readable by authenticated users only.
        // Sensitive fields (SMTP passwords, email credentials) are stripped
        // by the /api/public/settings route before reaching unauthenticated clients.
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
    
    match /tickets/{ticketId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isUser(resource.data.userId) || isAdmin();
      allow update: if (isUser(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'updatedAt', 'status'])) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
                    && request.resource.data.readBy == resource.data.readBy.concat([request.auth.uid]);
      allow delete: if isAdmin();
    }

    match /notifications_v2/{notifId} {
      // Allow reads if:
      // 1. User is in the recipientIds list (specific notification), OR
      // 2. target == 'all_users' (broadcast to everyone)
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.recipientIds ||
        resource.data.target == 'all_users'
      );
      // Only the server (Admin SDK via API route) can create notifications
      allow create: if isAdmin();
      // Any signed-in user can mark a notification as read
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
        && request.resource.data.readBy == resource.data.readBy.concat([request.auth.uid]);
      allow delete: if isAdmin();
    }

    match /user_notification_prefs/{userId} {
      allow read, write: if isUser(userId) || isAdmin();
    }

    match /push_subscriptions/{userId}/devices/{deviceId} {
      allow read, write: if isUser(userId) || isAdmin();
    }
  }
}
