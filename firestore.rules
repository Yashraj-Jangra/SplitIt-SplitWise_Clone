
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Check for the custom 'admin' claim on the user's token.
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // --- Collections ---
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isUser(userId) || isAdmin();
      allow delete: if isAdmin(); 
    }
    
    match /groups/{groupId} {
      // Admins have full access. This rule is checked first.
      allow read, write: if isAdmin();
      
      // Members can read groups they belong to. 
      // The client is responsible for filtering out archived groups from LIST views.
      // A direct GET of an archived group will be blocked by UI logic, not this rule.
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      
      // Any authenticated user can create a group.
      allow create: if isSignedIn();
      
      // Members can update a group ONLY if it is not archived.
      allow update: if (request.auth.uid in resource.data.memberIds) && (resource.data.archivedAt == null);
    }

    match /expenses/{expenseId} {
      // Admins have full access.
      allow read, write: if isAdmin();
      
      // Members can read expenses in groups they belong to.
      allow read: if isSignedIn() && request.auth.uid in resource.data.groupMemberIds;

      // Writes are only allowed if the group is active and user is a member.
      // This requires a get() on the parent group document.
      allow write: if get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.archivedAt == null 
                   && (request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds);
    }
    
    match /settlements/{settlementId} {
       // Admins have full access.
       allow read, write: if isAdmin();
      
      // Members can read settlements in groups they belong to.
      allow read: if isSignedIn() && request.auth.uid in resource.data.groupMemberIds;

      // Writes are only allowed if the group is active and user is a member.
      allow write: if get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.archivedAt == null
                   && (request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.memberIds);
    }
    
    match /history/{historyId} {
        allow read, write: if isAdmin();
        
        // Members can read history for their groups.
        allow read: if isSignedIn() && request.auth.uid in resource.data.groupMemberIds;

        // History is mostly created on the server. Client can only update `restored` flag.
        allow create: if isSignedIn();
        allow update: if (request.auth.uid in resource.data.groupMemberIds)
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['restored']);
    }
    
    match /settings/{docId} {
        allow read: if true; 
        allow write: if isAdmin();
    }
    
    match /tickets/{ticketId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isUser(resource.data.userId) || isAdmin();
      allow update: if (isUser(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'updatedAt', 'status'])) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
                    && request.resource.data.readBy == resource.data.readBy.concat([request.auth.uid]);
      allow delete: if isAdmin();
    }
  }
}
